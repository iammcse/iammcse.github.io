{
  "manifest_version": 3,
  "name": "KSC hub",
  "version": "1.0.0",
  "key": "", 
  "description": "Automatically enable/disable extensions and manage startup tabs based on local time rules.",
  "permissions": [
    "management",
    "storage",
    "alarms",
    "tabs",
    "identity"
  ],
  "host_permissions": [
    "https://github.com/login/oauth/access_token",
    "https://api.github.com/*",
    "https://oauth2.googleapis.com/*",
    "https://www.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "KSC hub"
  }
}
